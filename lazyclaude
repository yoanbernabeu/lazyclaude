#!/bin/bash
session="lazyclaude-$(basename "$PWD")"

# --- iTerm2 tmux CC mode detection ---
USE_CC=false
if [ "$TERM_PROGRAM" = "iTerm.app" ]; then
  USE_CC=true
fi

for arg in "$@"; do
  case "$arg" in
    --cc) USE_CC=true ;;
    --no-cc) USE_CC=false ;;
  esac
done

tmux_attach() {
  if $USE_CC; then
    tmux -CC attach -t "$1"
  else
    tmux attach -t "$1"
  fi
}

start_session() {
  # Create session detached, then set up panes
  tmux new-session -s "$session" -d "claude"
  tmux select-pane -T "CLAUDE" -t "$session"
  tmux split-window -h -t "$session" -p 40 \
    "echo ''; echo '  🚀 Welcome to LazyClaude!'; echo ''; echo '  📂 Type \"yazi\" to browse your files'; echo '  🔀 LazyGit is right below'; echo '  🤖 Claude Code is on the left pane'; echo ''; exec $SHELL"
  tmux select-pane -T "TERMINAL" -t "$session"
  tmux split-window -v -t "$session" -p 50 "lazygit"
  tmux select-pane -T "LAZYGIT" -t "$session"
  tmux select-pane -t "${session}:0.0"

  # Attach with or without CC mode
  if $USE_CC; then
    echo "🍎 iTerm2 detected — using native tmux integration (CC mode)"
  fi
  tmux_attach "$session"
}

# List existing lazyclaude sessions
existing=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^lazyclaude-" || true)

if [ -n "$existing" ]; then
  echo "🟢 Active lazyclaude sessions:"
  echo ""
  i=1
  while IFS= read -r s; do
    echo "  $i) $s"
    i=$((i + 1))
  done <<< "$existing"
  echo ""
  echo "What do you want to do?"
  echo "  a) Attach to an existing session"
  echo "  n) New session ($session)"
  echo "  k) Kill a session"
  echo "  K) Kill ALL sessions"
  echo "  q) Quit"
  echo ""
  read -rp "Choice: " choice

  case "$choice" in
    a)
      if [ "$(echo "$existing" | wc -l)" -eq 1 ]; then
        tmux_attach "$existing"
      else
        read -rp "Session number: " num
        target=$(echo "$existing" | sed -n "${num}p")
        if [ -n "$target" ]; then
          tmux_attach "$target"
        else
          echo "Invalid session."
        fi
      fi
      ;;
    n)
      if tmux has-session -t "$session" 2>/dev/null; then
        echo "⚠️  Session $session already exists. Use 'a' to attach or 'k' to kill it."
      else
        start_session
      fi
      ;;
    k)
      read -rp "Session number to kill: " num
      target=$(echo "$existing" | sed -n "${num}p")
      if [ -n "$target" ]; then
        tmux kill-session -t "$target"
        echo "✅ Session $target killed."
      else
        echo "Invalid session."
      fi
      start_session
      ;;
    K)
      echo "$existing" | while IFS= read -r s; do
        tmux kill-session -t "$s"
      done
      echo "✅ All lazyclaude sessions killed."
      start_session
      ;;
    q)
      exit 0
      ;;
    *)
      echo "Invalid choice."
      ;;
  esac
else
  start_session
fi
